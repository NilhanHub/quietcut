{
  "name": "quietcut",
  "version": "1.0.0",
  "description": "QuietCut - Premium Local Silence Cutter Desktop App",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on http://localhost:5173 && npm run build:electron && electron .",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build",
    "build:electron": "node scripts/build-electron.mjs",
    "package": "npm run build && electron-builder --win --config",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "build": {
    "appId": "com.quietcut.app",
    "productName": "QuietCut",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": null
    }
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "electron": "^39.8.5",
    "electron-builder": "^26.0.12",
    "jsdom": "^26.0.0",
    "esbuild": "^0.25.2",
    "typescript": "^5.8.3",
    "vite": "^6.3.2",
    "vitest": "^3.1.1",
    "wait-on": "^8.0.3"
  }
}
